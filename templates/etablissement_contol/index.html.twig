{% extends 'base.html.twig' %}

{% block title %}Etablissement index{% endblock %}

{% block body %}
    <h1>Etablissement index</h1>

    <table class="table">
        
        <tbody>
        {% for etablissement in etablissements %}
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Pays</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tr>
                <td>{{ etablissement.id }}</td>
                <td>{{ etablissement.nom }}</td>
                <td>{{ etablissement.ville }}</td>
                <td>{{ etablissement.pays }}</td>
                <td>
                    <a href="{{ path('app_etablissement_contol_show', {'id': etablissement.id}) }}">show</a>
                    <a href="{{ path('app_etablissement_contol_edit', {'id': etablissement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Pas d'Établissements</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_etablissement_contol_new') }}">Create new</a>
{% endblock %}
