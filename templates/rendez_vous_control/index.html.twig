{% extends 'base.html.twig' %}

{% block title %}RendezVous index{% endblock %}

{% block body %}
    <h1>RendezVous index</h1>

    <table class="table">
        
        <tbody>
        {% for rendez_vou in rendez_vouses %}
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tr>
                <td>{{ rendez_vou.id }}</td>
                <td>{{ rendez_vou.date ? rendez_vou.date|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ rendez_vou.statut }}</td>
                <td>
                    <a href="{{ path('app_rendez_vous_control_show', {'id': rendez_vou.id}) }}">show</a>
                    <a href="{{ path('app_rendez_vous_control_edit', {'id': rendez_vou.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_rendez_vous_control_new') }}">Create new</a>
{% endblock %}
