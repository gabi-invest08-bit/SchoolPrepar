{% extends 'base.html.twig' %}

{% block title %}Filiere index{% endblock %}

{% block body %}
    <h1>Filiere index</h1>

    <table class="table">
       
        <tbody>
        {% for filiere in filieres %}
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tr>
                <td>{{ filiere.id }}</td>
                <td>{{ filiere.nom }}</td>
                <td>{{ filiere.description }}</td>
                <td>
                    <a href="{{ path('app_filiere_control_show', {'id': filiere.id}) }}">show</a>
                    <a href="{{ path('app_filiere_control_edit', {'id': filiere.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_filiere_control_new') }}">Create new</a>
{% endblock %}
